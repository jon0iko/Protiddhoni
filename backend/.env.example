# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# Auth
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

# Web Push Notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:protiddhoni@example.com

# W&B Serverless Inference (quiz question generation)
# API key: https://wandb.ai/settings  |  Models: https://docs.wandb.ai/inference/models
WANDB_API_KEY=
# Optional — "<team>/<project>", used by W&B for usage attribution
WANDB_PROJECT=
# Optional overrides
WANDB_INFERENCE_MODEL=deepseek-ai/DeepSeek-V3.1
WANDB_INFERENCE_BASE_URL=https://api.inference.wandb.ai/v1